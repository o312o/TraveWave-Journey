rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User runtime email: 312working@gmail.com
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == '312working@gmail.com'
      ); 
    }

    // 0.1 Internal Probe
    match /_internal_/probe {
      allow read: if isSignedIn();
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && data.email.size() <= 200 &&
               data.initialCapital is number &&
               data.currentBalance is number &&
               data.peakEquity is number &&
               data.keys().hasAll(['email', 'initialCapital', 'currentBalance', 'peakEquity']) &&
               data.keys().size() <= 12;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (
            incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'currentBalance', 'peakEquity', 'updatedAt'])
        )
      );
    }

    // 2. Trades Collection
    match /users/{userId}/trades/{tradeId} {
      function isValidTrade(data) {
        return data.userId == userId &&
               data.asset is string && data.asset.size() <= 64 &&
               data.type in ['LONG', 'SHORT'] &&
               data.status in ['OPEN', 'CLOSED'] &&
               data.keys().hasAll(['asset', 'type', 'status', 'userId']) &&
               data.keys().size() <= 25;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(tradeId) && isValidTrade(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidTrade(incoming()) && (
        isAdmin() || (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'exitPrice', 'pnl', 'pnlPercentage', 'notes', 'screenshotUrl', 'updatedAt']) &&
          incoming().userId == existing().userId
        )
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // 3. Settings Collection
    match /users/{userId}/settings/risk {
      allow get, write: if isOwner(userId) || isAdmin();
    }
  }
}
